# Server Configuration
# The port the Express server will listen on.
PORT="4000"

# The name of the application, used in logs and UI.
TITLE="Parity"

# Set to "true" for production environments to enable optimizations.
PRODUCTION="false"

# If true, forces https to use IPv4. Useful if there are networking issues with IPv6.
FORCE_FAMILY_4="true"

# If true, the process will exit upon encountering an uncaught exception.
EXIT_ON_UNCAUGHT_EXCEPTION="true"

# If true, the process will exit upon encountering an unhandled promise rejection.
EXIT_ON_UNHANDLED_REJECTION="true"

# The base URL of the production server.
PROD_URL="https://example.com"

# Maximum allowed weight for flow logs. Controls logging verbosity.
MAX_ALLOWED_FLOG_LOG_WEIGHT="5"

# Groq LLM Configuration
# Set to "true" to enable AI-powered verdicts and analysis.
GROQ_USE="true"

# Your Groq API Key. Keep this secret!
GROQ_KEY="your_api_key_here"

# The endpoint for the Groq API.
GROQ_ENDPOINT="https://api.groq.com/openai/v1/chat/completions"

# Space-separated list of model IDs to use. The system may rotate through these.
# allam-2-7b groq/compound groq/compound-mini
# llama-3.1-8b-instant llama-3.3-70b-versatile llama3-70b-8192 llama3-8b-8192 
# meta-llama/llama-4-maverick-17b-128e-instruct meta-llama/llama-4-scout-17b-16e-instruct 
# meta-llama/llama-guard-4-12b meta-llama/llama-prompt-guard-2-22m 
# meta-llama/llama-prompt-guard-2-86m mistral-saba-24b qwen-qwq-32b qwen/qwen3-32b
# moonshotai/kimi-k2-instruct moonshotai/kimi-k2-instruct-0905
# openai/gpt-oss-20b openai/gpt-oss-120b
GROQ_MODELS="moonshotai/kimi-k2-instruct-0905 openai/gpt-oss-20b openai/gpt-oss-120b qwen/qwen3-32b groq/compound groq/compound-mini"

# Request timeout for Groq API calls in milliseconds. 0 means no timeout.
GROQ_REQUEST_TIMEOUT_MS="0"

# Maximum number of retries for failed Groq API requests.
GROQ_MAX_RETRIES="4"

# HTTP timeout for Groq API connections in milliseconds.
GROQ_HTTP_TIMEOUT_MS="60000"

# Number of previous messages to maintain in the LLM conversation history.
GROQ_MAX_HISTORY_COUNT="5"

# Engine Timing & Logic
# System Interval: The delay between background processing cycles in milliseconds.
SYS_INT="3600000"

# Wait Hours: The number of hours in timespan for fetching upcoming events... e.g. 24 means fetch all scheduled events in the next 24 hours.
WAIT_HOURS="2"

# Minimum draw score required to get an LLM verdict.
LLM_MIN_DRAW_SCORE="0.4"
